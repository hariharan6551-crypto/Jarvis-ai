{
  "name": "jarvis-ai",
  "version": "1.0.0",
  "private": true,
  "description": "J.A.R.V.I.S - Advanced AI Desktop Assistant",
  "scripts": {
    "dev": "cd frontend && npm run dev",
    "build": "cd frontend && npm run build",
    "preview": "cd frontend && npm run preview",
    "electron": "cd frontend && npm run electron",
    "electron:dev": "cd frontend && npm run electron:dev",
    "install:frontend": "cd frontend && npm install",
    "install:backend": "cd backend && pip install -r requirements.txt",
    "start:backend": "cd backend && python -m uvicorn main:app --reload --port 8000",
    "start": "concurrently \"npm run start:backend\" \"npm run dev\""
  }
}
